{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node", "vite/client"],
    "strict": true
  },
  "vueCompilerOptions": {
    "vitePressExtensions": [".md", ".mdx"]
  },
  "include": [
    ".vitepress/**/*.ts",
    ".vitepress/**/*.vue",
    "src/**/*.ts",
    "src/**/*.vue",
    "src/**/*.md",
    "src/**/*.mdx",
  ]
}
